# syntax=docker/dockerfile:1
#
# Self-contained pimm *dev* image: the locked environment AND the pimm source are
# baked in, so the image runs standalone on Google Cloud Batch, where there is no
# host checkout to bind-mount (unlike the standard image in ./Dockerfile, which
# ships only the environment). Built and published by
# .github/workflows/docker-dev.yml as docker.io/<user>/pimm_dev:vN.

ARG TORCH_VERSION=2.10.0
ARG CUDA_VERSION=12.6
ARG CUDNN_VERSION=9
FROM pytorch/pytorch:${TORCH_VERSION}-cuda${CUDA_VERSION}-cudnn${CUDNN_VERSION}-devel

COPY --from=ghcr.io/astral-sh/uv:0.11.28 /uv /uvx /usr/local/uv/bin/

ARG TORCH_CUDA_ARCH_LIST="7.0 7.5 8.0 8.6 8.9 9.0"
ENV CUDA_HOME=/usr/local/cuda \
    FORCE_CUDA=1 \
    MAX_JOBS=1 \
    PATH=/opt/pimm/.venv/bin:/usr/local/uv/bin:$PATH \
    PYTHONNOUSERSITE=1 \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    UV_LINK_MODE=copy \
    UV_PYTHON_INSTALL_DIR=/opt/uv/python \
    UV_PROJECT_ENVIRONMENT=/opt/pimm/.venv

RUN rm -f /etc/apt/sources.list.d/*.list
COPY .github/docker/common /opt/pimm/.github/docker/common
RUN bash /opt/pimm/.github/docker/common/install_system.sh

# Resolve the locked environment first, from the dependency manifests only, so
# this expensive layer is cached across source-only changes.
WORKDIR /opt/pimm
COPY pyproject.toml uv.lock .python-version ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --no-install-project

COPY .github/docker/pimm /usr/local/bin/pimm
COPY .github/docker/entrypoint.sh /opt/pimm/entrypoint.sh
RUN chmod +x /usr/local/bin/pimm /opt/pimm/entrypoint.sh

# Bake the full source in and install the project into the venv, so `pimm` and
# `import pimm` resolve even when Cloud Batch overrides the entrypoint (bypassing
# the cwd-on-PYTHONPATH shim). /opt/pimm/src is the working directory the gcloud
# site's paths.repo_root points at.
COPY . /opt/pimm/src
WORKDIR /opt/pimm/src
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked

ENTRYPOINT ["/opt/pimm/entrypoint.sh"]
CMD ["bash"]
