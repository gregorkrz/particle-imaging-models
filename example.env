# Run "cp example.env .env" and modify .env.
# These are loaded automatically by pimm/train.py and pimm/test.py.
# Existing environment variables take priority over values here.

# Dataset paths (set after running: python tools/download_pilarnet.py --version v2 --output-dir /path/to/output/dir)
# PILARNET_DATA_ROOT_V1=/path/to/pilarnet/v1
# PILARNET_DATA_ROOT_V2=/path/to/pilarnet/v2

# Redirect checkpoints to a separate disk, if you want.
# MODEL_DIR=/scratch/models

# Weights & Biases API key (alternative to running `uv run wandb login`)
# Get yours at https://wandb.ai/authorize
# WANDB_API_KEY=your_key_here

# HuggingFace API key (alternative to running `uv run hf login`)
# HF_TOKEN=your_token_here
